    {
      "id": 701,
      "type": "text",
      "title": "Write Approval Level",
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 0,
        "y": 80
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"font-family:monospace;background:#111827;padding:14px;height:100%;box-sizing:border-box\"><div style=\"font-size:12px;color:#9ca3af;margin-bottom:10px\">GLOBAL APPROVAL LEVEL</div><div id=\"level-badge\" style=\"font-size:22px;font-weight:bold;margin-bottom:12px;color:#73bf69\">Loading...</div><div id=\"level-desc\" style=\"font-size:11px;color:#9ca3af;margin-bottom:16px;min-height:28px\"></div><div style=\"display:flex;gap:8px;flex-wrap:wrap\"><button onclick=\"setLvl(1)\" id=\"b1\" style=\"flex:1;padding:8px;border:2px solid transparent;border-radius:6px;cursor:pointer;font-family:monospace;font-size:12px;font-weight:bold;background:#1f2937;color:#fca5a5\">Level 1<br><span style=\"font-weight:normal;font-size:10px\">All writes</span></button><button onclick=\"setLvl(2)\" id=\"b2\" style=\"flex:1;padding:8px;border:2px solid transparent;border-radius:6px;cursor:pointer;font-family:monospace;font-size:12px;font-weight:bold;background:#1f2937;color:#fde68a\">Level 2<br><span style=\"font-weight:normal;font-size:10px\">Critical only</span></button><button onclick=\"setLvl(3)\" id=\"b3\" style=\"flex:1;padding:8px;border:2px solid transparent;border-radius:6px;cursor:pointer;font-family:monospace;font-size:12px;font-weight:bold;background:#1f2937;color:#86efac\">Level 3<br><span style=\"font-weight:normal;font-size:10px\">Breaking only</span></button></div></div><script>var B='';var INFO={1:{c:'#f87171',d:'All write operations need your approval before executing'},2:{c:'#fbbf24',d:'Only critical/breaking writes need approval \u2014 standard writes execute directly'},3:{c:'#34d399',d:'Only potentially breaking changes need approval'}};async function load(){try{var r=await fetch(B+'/api/v1/approval/level');var d=await r.json();var lvl=d.level||1;var info=INFO[lvl];document.getElementById('level-badge').textContent='Level '+lvl;document.getElementById('level-badge').style.color=info.c;document.getElementById('level-desc').textContent=info.d;[1,2,3].forEach(function(n){var btn=document.getElementById('b'+n);btn.style.border='2px solid '+(n===lvl?INFO[n].c:'transparent');});}catch(e){document.getElementById('level-badge').textContent='Error';}}async function setLvl(n){try{await fetch(B+'/api/v1/approval/level',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({level:n})});load();}catch(e){}}load();setInterval(load,10000);</script>"
      }
    },
    {
      "id": 702,
      "type": "text",
      "title": "Pending Approvals",
      "gridPos": {
        "h": 7,
        "w": 14,
        "x": 10,
        "y": 80
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"font-family:monospace;background:#111827;padding:14px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;gap:8px\"><div style=\"display:flex;justify-content:space-between;align-items:center\"><span style=\"font-size:12px;color:#9ca3af\">PENDING WRITE TASKS</span><button onclick=\"load()\" style=\"background:#374151;color:#9ca3af;border:none;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:10px\">Refresh</button></div><div id=\"pt-status\" style=\"font-size:11px;color:#6b7280\"></div><div id=\"pt-table\" style=\"flex:1;overflow-y:auto\"></div></div><script>var B='';var CAT={standard:{c:'#93c5fd',l:'standard'},critical:{c:'#fbbf24',l:'critical'},breaking:{c:'#f87171',l:'breaking'}};async function approve(id){document.getElementById('pt-status').textContent='Approving...';await fetch(B+'/api/v1/approval/approve/'+id,{method:'POST'});load();}async function cancel(id){await fetch(B+'/api/v1/approval/cancel/'+id,{method:'POST'});load();}async function load(){try{var r=await fetch(B+'/api/v1/approval/pending');var d=await r.json();var tasks=d.tasks||[];var el=document.getElementById('pt-table');if(!tasks.length){el.innerHTML='<div style=\"color:#6b7280;font-size:12px;padding:8px\">No pending approvals</div>';document.getElementById('pt-status').textContent='';return;}var rows=tasks.map(function(t){var ci=CAT[t.category]||{c:'#9ca3af',l:t.category};var ts=new Date(t.created_at).toLocaleTimeString();return'<tr style=\"border-bottom:1px solid #1f2937\"><td style=\"padding:4px 6px;font-size:11px;color:'+ci.c+'\">'+ci.l+'</td><td style=\"padding:4px 6px;font-size:11px;color:#d1d5db;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap\">'+t.title+'</td><td style=\"padding:4px 6px;font-size:10px;color:#6b7280\">'+ts+'</td><td style=\"padding:4px 6px;white-space:nowrap\"><button onclick=\"approve(\\\"'+t.task_id+'\\\")\" style=\"background:#14532d;color:#86efac;border:none;padding:2px 7px;border-radius:3px;cursor:pointer;font-size:11px;margin-right:4px\">Approve</button><button onclick=\"cancel(\\\"'+t.task_id+'\\\")\" style=\"background:#7f1d1d;color:#fca5a5;border:none;padding:2px 7px;border-radius:3px;cursor:pointer;font-size:11px\">Cancel</button></td></tr>';}).join('');el.innerHTML='<table style=\"width:100%;border-collapse:collapse\"><thead><tr><th style=\"padding:4px 6px;text-align:left;font-size:10px;color:#6b7280\">Category</th><th style=\"padding:4px 6px;text-align:left;font-size:10px;color:#6b7280\">Task</th><th style=\"padding:4px 6px;text-align:left;font-size:10px;color:#6b7280\">Time</th><th></th></tr></thead><tbody>'+rows+'</tbody></table>';document.getElementById('pt-status').textContent=tasks.length+' waiting';}catch(e){document.getElementById('pt-status').textContent='Error: '+e.message;}}load();setInterval(load,5000);</script>"
      }
    },
    {
      "id": 30,
      "type": "text",
      "title": "Chat with Brain",
      "gridPos": {
        "h": 20,
        "w": 14,
        "x": 0,
        "y": 80
      },
      "options": {
        "mode": "html",
        "content": "<div id=\"brain-chat\" style=\"font-family:monospace;background:#111827;padding:12px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;gap:8px\"><div style=\"display:flex;justify-content:space-between;align-items:center\"><span style=\"color:#93c5fd;font-size:13px;font-weight:bold\">Brain Chat</span><button onclick=\"clearSession()\" style=\"background:#374151;color:#9ca3af;border:none;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:11px\">Clear</button></div><div id=\"msgs\" style=\"flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:6px;min-height:0\"></div><div style=\"display:flex;gap:6px\"><textarea id=\"inp\" rows=\"2\" placeholder=\"Message Brain... (Enter to send)\" style=\"flex:1;background:#1f2937;color:#e5e7eb;border:1px solid #374151;border-radius:6px;padding:8px;font-size:13px;font-family:monospace;resize:none\"></textarea><button onclick=\"sendMsg()\" id=\"sendBtn\" style=\"background:#3b82f6;color:#fff;border:none;padding:8px 14px;border-radius:6px;cursor:pointer;font-weight:bold;font-size:13px;align-self:flex-end\">Send</button></div><div id=\"chat-status\" style=\"font-size:11px;color:#6b7280\"></div></div><script>var _sid='dashboard-'+Math.random().toString(36).slice(2,8);function addMsg(role,text){var msgs=document.getElementById('msgs');var d=document.createElement('div');d.style.cssText='padding:8px 10px;border-radius:6px;max-width:92%;word-break:break-word;font-size:13px;line-height:1.5;white-space:pre-wrap;'+(role==='user'?'background:#1e3a5f;color:#93c5fd;align-self:flex-end':'background:#1f2937;color:#d1d5db;align-self:flex-start');d.textContent=text;msgs.appendChild(d);msgs.scrollTop=msgs.scrollHeight;}async function sendMsg(){var inp=document.getElementById('inp');var btn=document.getElementById('sendBtn');var msg=inp.value.trim();if(!msg)return;addMsg('user',msg);inp.value='';btn.disabled=true;document.getElementById('chat-status').textContent='Thinking...';try{var r=await fetch('/api/v1/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,session_id:_sid})});var data=await r.json();addMsg('brain',data.reply||data.detail||'No response');document.getElementById('chat-status').textContent='intent: '+data.intent+' | agent: '+data.agent;}catch(e){addMsg('brain','Error: '+e.message);document.getElementById('chat-status').textContent='';}btn.disabled=false;}function clearSession(){fetch('/api/v1/chat/'+_sid,{method:'DELETE'});document.getElementById('msgs').innerHTML='';document.getElementById('chat-status').textContent='Session cleared';}document.getElementById('inp').addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}});</script>"
      }
    },
    {
      "id": 31,
      "type": "text",
      "title": "Task Queue Control",
      "gridPos": {
        "h": 20,
        "w": 10,
        "x": 14,
        "y": 80
      },
      "options": {
        "mode": "html",
        "content": "<div style=\"font-family:monospace;background:#111827;padding:12px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;gap:8px\"><div style=\"display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:4px\"><span style=\"color:#93c5fd;font-size:13px;font-weight:bold\">Task Queue</span><div style=\"display:flex;gap:4px;flex-wrap:wrap\"><button onclick=\"pauseWorkers()\" style=\"background:#7f1d1d;color:#fca5a5;border:none;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:11px;font-weight:bold\">Pause Workers</button><button onclick=\"resumeWorkers()\" style=\"background:#14532d;color:#86efac;border:none;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:11px;font-weight:bold\">Resume Workers</button><button onclick=\"loadTasks()\" style=\"background:#374151;color:#9ca3af;border:none;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:11px\">Refresh</button></div></div><div id=\"task-status\" style=\"font-size:11px;color:#6b7280\"></div><div id=\"task-table\" style=\"flex:1;overflow-y:auto\"></div></div><script>function renderTasks(data){var all=[];['active','reserved','scheduled'].forEach(function(type){Object.entries(data[type]||{}).forEach(function(kv){(kv[1]||[]).forEach(function(t){all.push(Object.assign({_type:type,_worker:kv[0]},t));});});});var el=document.getElementById('task-table');if(!all.length){el.innerHTML='<div style=\"color:#6b7280;font-size:12px;padding:8px\">No tasks \u2014 queue is idle</div>';return;}var clr={active:'#86efac',reserved:'#93c5fd',scheduled:'#fde68a'};var rows=all.map(function(t){return'<tr><td style=\"padding:4px 6px\"><span style=\"color:'+(clr[t._type]||'#9ca3af')+';font-size:11px\">'+t._type+'</span></td><td style=\"padding:4px 6px;color:#d1d5db;font-size:11px\">'+((t.name||'').split('.').pop())+'</td><td style=\"padding:4px 6px;color:#6b7280;font-size:10px\">'+((t.id||'').slice(0,8))+'\u2026</td><td style=\"padding:4px 6px\"><button onclick=\"revoke(\\\"'+t.id+'\\\")\" style=\"background:#374151;color:#f87171;border:none;padding:2px 6px;border-radius:3px;cursor:pointer;font-size:11px\">Revoke</button></td></tr>';}).join('');el.innerHTML='<table style=\"width:100%;border-collapse:collapse\"><thead><tr><th style=\"padding:4px 6px;text-align:left;color:#6b7280;font-size:10px\">State</th><th style=\"padding:4px 6px;text-align:left;color:#6b7280;font-size:10px\">Task</th><th style=\"padding:4px 6px;text-align:left;color:#6b7280;font-size:10px\">ID</th><th></th></tr></thead><tbody>'+rows+'</tbody></table>';}async function loadTasks(){document.getElementById('task-status').textContent='Loading...';try{var r=await fetch('/api/v1/tasks');if(!r.ok)throw new Error(r.statusText);renderTasks(await r.json());document.getElementById('task-status').textContent='Updated '+new Date().toLocaleTimeString();}catch(e){document.getElementById('task-status').textContent='Error: '+e.message;}}async function revoke(id){document.getElementById('task-status').textContent='Revoking '+id.slice(0,8)+'...';await fetch('/api/v1/tasks/'+id+'?terminate=true',{method:'DELETE'});loadTasks();}async function pauseWorkers(){await fetch('/api/v1/workers/pause',{method:'POST'});document.getElementById('task-status').textContent='Workers paused \u2014 finishing current tasks then stopping';}async function resumeWorkers(){await fetch('/api/v1/workers/resume',{method:'POST'});document.getElementById('task-status').textContent='Workers resumed \u2014 pulling from queue';}loadTasks();setInterval(loadTasks,15000);</script>"
      }
    }
  ]
