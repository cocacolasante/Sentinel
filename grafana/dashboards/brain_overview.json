{
  "title": "AI Brain Overview",
  "uid": "brain-overview",
  "description": "AI Brain request traffic, LLM performance, Celery tasks, and Redis health",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "schemaVersion": 39,
  "tags": ["brain", "ai", "celery"],
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Request Rate",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(brain_requests_total[5m]))",
        "legendFormat": "req/s", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}] } } }
    },

    {
      "id": 2, "type": "stat", "title": "Error Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "100 * sum(rate(brain_requests_total{success=\"false\"}[5m])) / (sum(rate(brain_requests_total[5m])) > 0 or vector(0))",
        "legendFormat": "error %", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}] } } }
    },

    {
      "id": 3, "type": "stat", "title": "P95 Latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by(le) (rate(brain_response_latency_seconds_bucket[5m]))) * 1000",
        "legendFormat": "p95 ms", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":3000},{"color":"red","value":8000}] } } }
    },

    {
      "id": 4, "type": "stat", "title": "Celery Workers",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "celery_workers_online",
        "legendFormat": "workers", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color":"red","value":null},{"color":"green","value":1}] } } }
    },

    {
      "id": 5, "type": "timeseries", "title": "Request Rate & Errors",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(brain_requests_total[5m]))", "legendFormat": "total req/s", "refId": "A" },
        { "expr": "sum(rate(brain_requests_total{success=\"false\"}[5m]))", "legendFormat": "errors/s", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [{ "matcher": { "id": "byName", "options": "errors/s" }, "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"red"}}] }] },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 6, "type": "timeseries", "title": "Response Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le) (rate(brain_response_latency_seconds_bucket[5m]))) * 1000", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(brain_response_latency_seconds_bucket[5m]))) * 1000", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(brain_response_latency_seconds_bucket[5m]))) * 1000", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 7, "type": "timeseries", "title": "LLM Tokens / Minute",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(model, direction) (rate(brain_llm_tokens_total[1m]) * 60)", "legendFormat": "{{model}} {{direction}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 8, "type": "timeseries", "title": "LLM API Latency by Model",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, model) (rate(brain_llm_latency_seconds_bucket[5m]))) * 1000", "legendFormat": "{{model}} p95", "refId": "A" },
        { "expr": "histogram_quantile(0.50, sum by(le, model) (rate(brain_llm_latency_seconds_bucket[5m]))) * 1000", "legendFormat": "{{model}} p50", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 9, "type": "bargauge", "title": "Requests by Intent (last 1h)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sort_desc(sum by(intent) (increase(brain_requests_total[1h])))",
        "legendFormat": "{{intent}}", "refId": "A",
        "instant": true
      }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color":"blue","value":null}] } } }
    },

    {
      "id": 10, "type": "timeseries", "title": "Celery Tasks by State",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(state) (rate(celery_tasks_total[5m]))", "legendFormat": "{{state}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 11, "type": "stat", "title": "Celery Queue Depth",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(celery_queue_length)",
        "legendFormat": "queued tasks", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":10},{"color":"red","value":50}] } } }
    },

    {
      "id": 12, "type": "stat", "title": "Redis Memory",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "redis_memory_used_bytes",
        "legendFormat": "used", "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":500000000},{"color":"red","value":1000000000}] } } }
    },

    {
      "id": 13, "type": "timeseries", "title": "Redis Hit Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "100 * rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]) > 0 or vector(1))",
        "legendFormat": "hit rate %", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 14, "type": "timeseries", "title": "Redis Connected Clients",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "redis_connected_clients",
        "legendFormat": "clients", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 15, "type": "stat", "title": "Daily Spend vs Ceiling",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "brain_cost_usd_daily",   "legendFormat": "spent today", "refId": "A" },
        { "expr": "brain_cost_ceiling_usd", "legendFormat": "daily ceiling", "refId": "B" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "orientation": "horizontal" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":9}] } } }
    },

    {
      "id": 16, "type": "timeseries", "title": "Daily Cost Accumulation",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "brain_cost_usd_daily",   "legendFormat": "spent USD", "refId": "A" },
        { "expr": "brain_cost_ceiling_usd", "legendFormat": "ceiling USD", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" },
        "overrides": [{ "matcher": { "id": "byName", "options": "ceiling USD" }, "properties": [{"id":"color","value":{"mode":"fixed","fixedColor":"red"}},{"id":"custom.lineStyle","value":{"fill":"dash"}}] }]
      },
      "options": { "tooltip": { "mode": "multi" } }
    }

  ]
}
