# ============================================================
# AI Brain — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.
# ============================================================

# ── Brain Server ─────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
ENVIRONMENT=production

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=brain
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=aibrain
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_strong_password
REDIS_HOST=redis
REDIS_PORT=6379

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI (GPT-4o) — Phase 2+ ───────────────────────────────
OPENAI_API_KEY=

# ── Google Gemini — Phase 2+ ─────────────────────────────────
GEMINI_API_KEY=

# ── Slack Bot ────────────────────────────────────────────────
# xoxb- token from OAuth & Permissions → Install App
SLACK_BOT_TOKEN=xoxb-...
# From Basic Information → App Credentials
SLACK_SIGNING_SECRET=...
# xapp- token from Socket Mode → App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# ── n8n ──────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=changeme_strong_password
N8N_WEBHOOK_URL=http://n8n:5678

# ── Domain / Server ──────────────────────────────────────────
# Your server's domain or IP (used by Nginx)
DOMAIN=your-domain.com

# ── Timezone ─────────────────────────────────────────────────
TIMEZONE=America/Chicago

# ============================================================
# PHASE 2 — Integration Credentials
# ============================================================

# ── Google OAuth (Gmail + Calendar) ──────────────────────────
# Step 1: Create OAuth credentials in Google Cloud Console
#   https://console.cloud.google.com → APIs & Services → Credentials
#   Application type: Desktop app
# Step 2: Run: python scripts/google_auth.py
#   This will open a browser, ask you to sign in, and save the refresh token here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── GitHub ───────────────────────────────────────────────────
# Create a Personal Access Token at https://github.com/settings/tokens
# Scopes needed: repo, notifications, read:user
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=anthonycolasante
GITHUB_DEFAULT_REPO=anthonycolasante/my-repo

# ── Home Assistant ───────────────────────────────────────────
# Create a Long-Lived Access Token in HA:
#   Profile → Long-Lived Access Tokens → Create Token
HOME_ASSISTANT_URL=http://192.168.1.100:8123
HOME_ASSISTANT_TOKEN=eyJ0...
HOME_ASSISTANT_VERIFY_SSL=false
