# ============================================================
# Sentinel AI Brain — Environment Variables
# Copy this file to .env and fill in your actual values.
# ✅ = required   ⚠️ = recommended   🔒 = optional / leave blank to disable
# NEVER commit .env to Git.
# ============================================================

# ── Brain Server ✅ ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string
ENVIRONMENT=production

# ── PostgreSQL ✅ ─────────────────────────────────────────────────────────────
POSTGRES_USER=brain
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=aibrain
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ✅ ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_strong_password
REDIS_HOST=redis
REDIS_PORT=6379

# ── Qdrant (vector memory) ✅ ─────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=brain_memories
QDRANT_VECTOR_SIZE=1536

# ── Domain & Timezone ✅ ──────────────────────────────────────────────────────
# Public domain or IP — used by Nginx, webhook URLs, and Grafana dashboards
DOMAIN=your-domain.com
# IANA timezone name — used for calendar events
TIMEZONE=America/Chicago

# ══════════════════════════════════════════════════════════════════════════════
# LLM PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic (Claude) ✅ ─────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI ⚠️ ─────────────────────────────────────────────────────────────────
# Required for vector memory embeddings (text-embedding-3-small)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Google Gemini 🔒 ──────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# MESSAGING & BOTS
# ══════════════════════════════════════════════════════════════════════════════

# ── Slack Bot ✅ ──────────────────────────────────────────────────────────────
# https://api.slack.com/apps → your app
# OAuth & Permissions → Install App → Bot User OAuth Token (xoxb-)
SLACK_BOT_TOKEN=xoxb-...
# Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=...
# Socket Mode → App-Level Tokens → Create Token (xapp-)
SLACK_APP_TOKEN=xapp-...
# Channel names (no #) — create these channels in Slack first
SLACK_ALERT_CHANNEL=brain-alerts
SLACK_EVAL_CHANNEL=brain-evals

# ── WhatsApp via Twilio 🔒 ────────────────────────────────────────────────────
# https://console.twilio.com
# Account SID (starts with AC)
TWILIO_ACCOUNT_SID=
# Auth Token
TWILIO_AUTH_TOKEN=
# Sandbox: whatsapp:+14155238886   Production: whatsapp:+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=
#
# Webhook setup (required for incoming messages):
#   Twilio Console → Messaging → Senders → WhatsApp Senders → your number
#   Webhook URL: https://YOUR_DOMAIN/api/v1/whatsapp/incoming

# ══════════════════════════════════════════════════════════════════════════════
# GOOGLE INTEGRATIONS  (Gmail + Calendar) — Multi-Account
# ══════════════════════════════════════════════════════════════════════════════
# Skills: gmail_read, gmail_send, gmail_reply, calendar_read, calendar_write
#
# Setup per account:
#   1. https://console.cloud.google.com → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID  (Application type: Desktop app)
#   3. Enable: Gmail API, Google Calendar API
#   4. Run: python scripts/google_auth.py  → paste the refresh token below
#
# Usage in prompts:
#   "check my work email"           → routes to account named "work"
#   "what's on my personal calendar" → routes to account named "personal"
#   "check all my calendars"         → reads ALL configured accounts
# ─────────────────────────────────────────────────────────────────────────────

# ── Primary / Account 1 ✅ ────────────────────────────────────────────────────
GOOGLE_ACCOUNT_NAME=personal
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# 'primary' = your main calendar, or paste a specific Calendar ID
GOOGLE_CALENDAR_ID=primary

# ── Account 2 (optional) 🔒 ───────────────────────────────────────────────────
# GOOGLE_ACCOUNT_2_NAME=work
# GOOGLE_ACCOUNT_2_CLIENT_ID=
# GOOGLE_ACCOUNT_2_CLIENT_SECRET=
# GOOGLE_ACCOUNT_2_REFRESH_TOKEN=
# GOOGLE_ACCOUNT_2_CALENDAR_ID=primary

# ── Account 3 (optional) 🔒 ───────────────────────────────────────────────────
# GOOGLE_ACCOUNT_3_NAME=business
# GOOGLE_ACCOUNT_3_CLIENT_ID=
# GOOGLE_ACCOUNT_3_CLIENT_SECRET=
# GOOGLE_ACCOUNT_3_REFRESH_TOKEN=
# GOOGLE_ACCOUNT_3_CALENDAR_ID=primary

# ── Account 4 (optional) 🔒 ───────────────────────────────────────────────────
# GOOGLE_ACCOUNT_4_NAME=family
# GOOGLE_ACCOUNT_4_CLIENT_ID=
# GOOGLE_ACCOUNT_4_CLIENT_SECRET=
# GOOGLE_ACCOUNT_4_REFRESH_TOKEN=
# GOOGLE_ACCOUNT_4_CALENDAR_ID=primary

# ── Account 5 (optional) 🔒 ───────────────────────────────────────────────────
# GOOGLE_ACCOUNT_5_NAME=school
# GOOGLE_ACCOUNT_5_CLIENT_ID=
# GOOGLE_ACCOUNT_5_CLIENT_SECRET=
# GOOGLE_ACCOUNT_5_REFRESH_TOKEN=
# GOOGLE_ACCOUNT_5_CALENDAR_ID=primary

# ══════════════════════════════════════════════════════════════════════════════
# GITHUB  (issues, PRs, CI/CD, repo self-modification)
# ══════════════════════════════════════════════════════════════════════════════
# Skills: github_read, github_write, cicd_read, cicd_trigger, repo_read/write/commit
#
# Create a Personal Access Token (classic):
#   https://github.com/settings/tokens → Generate new token (classic)
#   Scopes: repo, workflow, notifications, read:user
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-github-username
# Default repo for github_read/write and cicd commands
GITHUB_DEFAULT_REPO=your-username/your-repo

# Brain's own repo — used by repo_read/write/commit to self-modify its codebase
# SSH URL (git@github.com:user/repo.git) — server SSH key must have push access
GITHUB_BRAIN_REPO_URL=git@github.com:your-username/your-repo.git
# SSH key path inside the container (mount your ~/.ssh in docker-compose.yml)
# REPO_SSH_KEY_PATH=/root/.ssh/id_ed25519

# ══════════════════════════════════════════════════════════════════════════════
# HOME ASSISTANT  (smart home control)
# ══════════════════════════════════════════════════════════════════════════════
# Skill: smart_home
#
# Token: HA → Profile → Long-Lived Access Tokens → Create Token
# ─────────────────────────────────────────────────────────────────────────────
# Use the Docker service name if HA is in the same compose network:
HOME_ASSISTANT_URL=http://home-assistant:8123
HOME_ASSISTANT_TOKEN=eyJ0...
HOME_ASSISTANT_VERIFY_SSL=false

# ══════════════════════════════════════════════════════════════════════════════
# IONOS CLOUD  (servers, VDCs, DNS)
# ══════════════════════════════════════════════════════════════════════════════
# Skills: ionos_cloud (datacenters, servers, SSH, deploy), ionos_dns (DNS records)
#
# Option A — API Token (recommended):
#   https://dcd.ionos.com → Management → API Tokens → Generate Token
# Option B — Basic auth (username = your IONOS account email):
#   Leave IONOS_TOKEN blank and fill USERNAME + PASSWORD instead
# ─────────────────────────────────────────────────────────────────────────────
IONOS_TOKEN=
IONOS_USERNAME=
IONOS_PASSWORD=

# SSH key for connecting to IONOS servers after creation.
# Generate: ssh-keygen -t ed25519 -C "brain-ionos" -f ~/.ssh/brain_ionos
# Add the public key to IONOS DCD → SSH Keys.
IONOS_SSH_PRIVATE_KEY=
IONOS_SSH_PUBLIC_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# n8n  (workflow automation)
# ══════════════════════════════════════════════════════════════════════════════
# Skills: n8n_execute (trigger webhooks), n8n_manage (create/list/activate workflows)
# ─────────────────────────────────────────────────────────────────────────────
N8N_HOST=your-domain.com
N8N_USER=admin
N8N_PASSWORD=changeme_strong_password
# Internal Docker URL — Brain calls n8n inside the compose network
N8N_WEBHOOK_URL=http://n8n:5678
# API key for workflow management: n8n UI → Settings → n8n API → Create API key
N8N_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# TELOS — Personal Context
# ══════════════════════════════════════════════════════════════════════════════
# Directory containing your telos/*.md personal context files (mounted in container)
TELOS_DIR=/home/ubuntu/ai-brain/telos
# How long (seconds) to cache telos files before re-reading from disk
TELOS_CACHE_TTL_SECONDS=300

# ══════════════════════════════════════════════════════════════════════════════
# OBSERVABILITY
# ══════════════════════════════════════════════════════════════════════════════

# ── Sentry (error tracking) ⚠️ ────────────────────────────────────────────────
# https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=
# API token for reading/managing issues via the sentry_read/manage skills
# https://sentry.io → Settings → Auth Tokens → Create New Token
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
# Webhook signing secret — Sentry → Internal Integration → Secret Token
# Leave blank to skip signature verification (only safe behind auth proxy)
SENTRY_WEBHOOK_SECRET=

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_DIR=/var/log/aibrain

# ══════════════════════════════════════════════════════════════════════════════
# COST TRACKING & RATE LIMITING
# ══════════════════════════════════════════════════════════════════════════════
# Hard daily spend ceiling — Brain refuses LLM calls once hit (0 = disabled)
DAILY_COST_CEILING_USD=10.0
# Slack alert thresholds as fractions of the ceiling (0.5 = 50%)
BUDGET_ALERT_THRESHOLDS=0.5,0.8,1.0
# Per-model daily token cap (input + output combined). 0 = unlimited
SONNET_DAILY_TOKEN_BUDGET=0
HAIKU_DAILY_TOKEN_BUDGET=0
# Per-session request rate limits
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=200

# ══════════════════════════════════════════════════════════════════════════════
# MEMORY
# ══════════════════════════════════════════════════════════════════════════════
MEMORY_FLUSH_INTERVAL_TURNS=10

# ══════════════════════════════════════════════════════════════════════════════
# DASHBOARDS & MONITORING
# ══════════════════════════════════════════════════════════════════════════════

# ── Flower (Celery task UI) ───────────────────────────────────────────────────
# Access at https://your-domain.com/flower/
FLOWER_USER=admin
FLOWER_PASSWORD=changeme_strong_password

# ── Grafana (metrics dashboard) ───────────────────────────────────────────────
# Access at https://your-domain.com/grafana/
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_strong_password

# ══════════════════════════════════════════════════════════════════════════════
# SSH KEYS  (server identity — used for GitHub push access)
# ══════════════════════════════════════════════════════════════════════════════
# Paste the full PEM private key content (-----BEGIN ... -----END ...)
# Used by repo_commit skill to push code changes to GitHub
SSH_KEY_PRIVATE=
SSH_KEY_PUB=
